# PKM Bridge Server - Environment Configuration Template
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!
#
# NOTE: Traefik domain is configured in docker-compose.yml labels
#       Update the Host() rule in docker-compose.yml with your domain

# =============================================================================
# API Configuration
# =============================================================================

# Your Anthropic API key (required)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxx...

# Default Claude model for new sessions (used for chat if MODEL_CHAT not set)
# Options: claude-haiku-4-5, claude-sonnet-4-6, claude-opus-4-6
MODEL=claude-haiku-4-5

# =============================================================================
# Multi-LLM Provider Keys (Optional — enables additional models in dropdown)
# =============================================================================

# OpenAI API key — enables GPT-4o, GPT-4o-mini, o3-mini
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API key — enables Gemini 2.5 Flash/Pro
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# OpenRouter API key — single key for many models (DeepSeek, Llama, Mistral, etc.)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Ollama API base URL — enables local open-source models (no key needed)
# Point to your Ollama server, e.g., http://mac-mini.local:11434
# OLLAMA_API_BASE=http://localhost:11434

# =============================================================================
# Role-Based Model Overrides (Optional)
# =============================================================================
# Each subsystem can use a different model. Defaults are sensible for Claude.
# Override with any model ID supported by your configured providers.
#
# MODEL_CHAT=claude-haiku-4-5         # Main chat (or MODEL env var)
# MODEL_VOICE=claude-haiku-4-5        # Voice transcription cleanup
# MODEL_RETROSPECTIVE=claude-opus-4-6 # Daily retrospective analysis
# MODEL_SCHEDULER=claude-sonnet-4-6   # Scheduled task execution
# MODEL_SELF_IMPROVEMENT=claude-sonnet-4-6  # Self-improvement agent

# =============================================================================
# Directory Paths (on Docker host)
# =============================================================================

# Path to your org-mode notes directory (read/write access needed)
# The container needs write access for the add_journal_note tool
ORG_DIR=/path/to/your/org-agenda

# Path to your Logseq notes directory (read-only)
# Leave blank if you don't use Logseq
LOGSEQ_DIR=/path/to/your/Logseq

# =============================================================================
# Authentication & Security
# =============================================================================

# Enable authentication (strongly recommended for production)
AUTH_ENABLED=true

# JWT Secret - Generate with:
# python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET

# Password hash - Generate with:
# python3 -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt(12)).decode())"
# No need to escape $ signs - they're passed directly to the container
PASSWORD_HASH=$2b$12$REPLACE_WITH_GENERATED_HASH

# Token expiry in hours (168 = 1 week)
TOKEN_EXPIRY_HOURS=168

# =============================================================================
# Server Configuration
# =============================================================================

# Server port (container internal - don't change unless needed)
PORT=8000

# Host binding inside container (0.0.0.0 listens on all interfaces)
HOST=0.0.0.0

# Enable debug mode (only for development, not production)
DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL database credentials
# These are used by both the database container and the app
DB_USER=pkm
DB_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# Database URL - use placeholders for automatic password encoding
# The {DB_PASSWORD} placeholder will be automatically URL-encoded
# so special characters like @, %, #, etc. are handled correctly
DATABASE_URL=postgresql://{DB_USER}:{DB_PASSWORD}@localhost:5432/pkm_db

# Note: In Docker, the hostname is 'postgres' instead of 'localhost'
# This is auto-configured in docker-compose.yml

# =============================================================================
# Speech-to-Text / Whisper (Optional - for voice input)
# =============================================================================

# STT provider: "groq" (free tier) or "openai"
STT_PROVIDER=groq

# Groq API key (if STT_PROVIDER=groq)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# =============================================================================
# TickTick Integration (Optional)
# =============================================================================

# Register your app at https://developer.ticktick.com/ to get these credentials
# Leave blank to disable TickTick integration

# TickTick OAuth credentials
# Note: If your secret contains # characters, wrap it in quotes
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=

# OAuth redirect URI - must match what you configured in TickTick Developer Portal
# For local dev: http://localhost:8000/auth/ticktick/callback
# For production: https://your-domain.com/auth/ticktick/callback
TICKTICK_REDIRECT_URI=http://localhost:8000/auth/ticktick/callback

# =============================================================================
# Google Calendar Integration (Optional)
# =============================================================================

# Create OAuth 2.0 credentials at https://console.cloud.google.com/
# 1. Create a new project or select existing
# 2. Enable Google Calendar API
# 3. Configure OAuth consent screen
# 4. Create OAuth 2.0 Client ID (Web application)
# 5. Add authorized redirect URIs (see below)

# Google OAuth credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth redirect URI - must match what you configured in Google Cloud Console
# For local dev: http://localhost:8000/auth/google-calendar/callback
# For production: https://your-domain.com/auth/google-calendar/callback
# Note: You can register BOTH URIs in the same Google OAuth client!
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google-calendar/callback

# =============================================================================
# Gmail Integration (Optional — uses same Google Cloud project as Calendar)
# =============================================================================

# Enable the Gmail API in Google Cloud Console (same project as Calendar)
# Add the redirect URI below to your OAuth client's authorized redirect URIs

# OAuth redirect URI for Gmail
# For local dev: http://localhost:8000/auth/google-gmail/callback
# For production: https://your-domain.com/auth/google-gmail/callback
GOOGLE_GMAIL_REDIRECT_URI=http://localhost:8000/auth/google-gmail/callback

# =============================================================================
# RAG (Retrieval-Augmented Generation) / Vector Database
# =============================================================================

# Voyage AI API key for semantic embeddings
# Get your API key from: https://voyageai.com
# Required for auto-injection RAG and semantic search
VOYAGE_API_KEY=

# Number of recent days of journal entries to include in context (default: 3)
# Higher values provide more temporal context but increase token usage
# Recommended: 3-7 days
RAG_RECENT_DAYS=3

# =============================================================================
# Command Execution Security
# =============================================================================

# Whitelist of commands allowed in execute_shell tool
# Comma-separated list, no spaces
# Default includes safe read-only commands
ALLOWED_COMMANDS=date,rg,ripgrep,grep,fd,find,cat,ls,emacs,git,sed,awk,head,tail,wc
