<script>
    // Constants for localStorage keys
    const STORAGE_KEYS = {
        AUTO_SAVE_ENABLED: 'pkm-autoSave',
        AUTO_SAVE_DELAY: 'pkm-autoSaveDelay',
    } as const;

    // User Context Management
    // Append the auth token to an OAuth /authorize URL. A full-page navigation
    // can't set an Authorization header and the endpoint now requires auth, so
    // the token rides along as ?token= (server accepts it for browser GETs).
    function authorizeUrl(path: string): string {
        const t = localStorage.getItem('pkm-authToken');
        return t ? `${path}?token=${encodeURIComponent(t)}` : path;
    }

    let originalContext = '';
    const contextTextarea = document.getElementById('user-context-textarea');
    const saveContextBtn = document.getElementById('save-context-btn');
    const cancelContextBtn = document.getElementById('cancel-context-btn');
    const contextStatus = document.getElementById('context-status');

    async function loadUserContext() {
        const token = localStorage.getItem('pkm-authToken');
        contextStatus.textContent = 'Loading...';
        contextStatus.className = 'status-text';

        try {
            const response = await fetch('/api/user-context', {
                headers: {
                    'Authorization': `Bearer ${token}`
                }
            });

            if (response.ok) {
                const data = await response.json();
                originalContext = data.user_context || '';
                contextTextarea.value = originalContext;
                contextStatus.textContent = '';
            } else {
                contextStatus.textContent = 'Failed to load user context';
                contextStatus.className = 'status-text error';
            }
        } catch (error) {
            console.error('Error loading user context:', error);
            contextStatus.textContent = 'Error loading user context';
            contextStatus.className = 'status-text error';
        }
    }

    async function saveUserContext() {
        const token = localStorage.getItem('pkm-authToken');
        const newContext = contextTextarea.value;

        saveContextBtn.disabled = true;
        contextStatus.textContent = 'Saving...';
        contextStatus.className = 'status-text';

        try {
            const response = await fetch('/api/user-context', {
                method: 'PUT',
                headers: {
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ user_context: newContext })
            });

            if (response.ok) {
                originalContext = newContext;
                contextStatus.textContent = 'Saved successfully!';
                contextStatus.className = 'status-text success';
                cancelContextBtn.style.display = 'none';

                // Clear success message after 3 seconds
                setTimeout(() => {
                    contextStatus.textContent = '';
                }, 3000);
            } else {
                const data = await response.json();
                contextStatus.textContent = `Failed to save: ${data.error || 'Unknown error'}`;
                contextStatus.className = 'status-text error';
            }
        } catch (error) {
            console.error('Error saving user context:', error);
            contextStatus.textContent = 'Error saving user context';
            contextStatus.className = 'status-text error';
        } finally {
            saveContextBtn.disabled = false;
        }
    }

    function cancelContextChanges() {
        contextTextarea.value = originalContext;
        cancelContextBtn.style.display = 'none';
        contextStatus.textContent = '';
    }

    // Track changes to show/hide cancel button
    contextTextarea?.addEventListener('input', () => {
        const hasChanges = contextTextarea.value !== originalContext;
        cancelContextBtn.style.display = hasChanges ? 'inline-block' : 'none';
    });

    // Button handlers
    saveContextBtn?.addEventListener('click', saveUserContext);
    cancelContextBtn?.addEventListener('click', cancelContextChanges);

    // TickTick Integration Management
    async function checkTickTickStatus() {
        const token = localStorage.getItem('pkm-authToken');
        const statusBadge = document.getElementById('ticktick-status');
        const connectBtn = document.getElementById('connect-ticktick');
        const disconnectBtn = document.getElementById('disconnect-ticktick');

        try {
            const response = await fetch('/auth/ticktick/status', {
                headers: {
                    'Authorization': `Bearer ${token}`
                }
            });

            const data = await response.json();

            if (data.connected) {
                statusBadge.textContent = 'Connected';
                statusBadge.className = 'status-badge connected';
                disconnectBtn.style.display = 'inline-block';
                connectBtn.style.display = 'none';
            } else {
                statusBadge.textContent = 'Not Connected';
                statusBadge.className = 'status-badge disconnected';
                connectBtn.style.display = 'inline-block';
                disconnectBtn.style.display = 'none';
            }
        } catch (error) {
            console.error('Error checking TickTick status:', error);
            statusBadge.textContent = 'Error';
            statusBadge.className = 'status-badge disconnected';
            connectBtn.style.display = 'inline-block';
        }
    }

    document.getElementById('connect-ticktick')?.addEventListener('click', () => {
        // Open authorization in same tab (full navigation can't set a header,
        // so pass the token as ?token= — the /authorize endpoint requires auth)
        window.location.href = authorizeUrl('/auth/ticktick/authorize');
    });

    document.getElementById('disconnect-ticktick')?.addEventListener('click', async () => {
        if (!confirm('Are you sure you want to disconnect TickTick?')) {
            return;
        }

        const token = localStorage.getItem('pkm-authToken');

        try {
            const response = await fetch('/auth/ticktick/disconnect', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${token}`
                }
            });

            if (response.ok) {
                alert('TickTick disconnected successfully');
                checkTickTickStatus();
            } else {
                alert('Failed to disconnect TickTick');
            }
        } catch (error) {
            console.error('Error disconnecting TickTick:', error);
            alert('Error disconnecting TickTick');
        }
    });

    // Google Calendar Integration Management
    async function checkGoogleCalendarStatus() {
        const token = localStorage.getItem('pkm-authToken');
        const statusBadge = document.getElementById('google-calendar-status');
        const connectBtn = document.getElementById('connect-google-calendar');
        const disconnectBtn = document.getElementById('disconnect-google-calendar');

        try {
            const response = await fetch('/auth/google-calendar/status', {
                headers: {
                    'Authorization': `Bearer ${token}`
                }
            });

            const data = await response.json();

            if (data.connected) {
                statusBadge.textContent = 'Connected';
                statusBadge.className = 'status-badge connected';
                disconnectBtn.style.display = 'inline-block';
                connectBtn.style.display = 'none';
            } else {
                statusBadge.textContent = 'Not Connected';
                statusBadge.className = 'status-badge disconnected';
                connectBtn.style.display = 'inline-block';
                disconnectBtn.style.display = 'none';
            }
        } catch (error) {
            console.error('Error checking Google Calendar status:', error);
            statusBadge.textContent = 'Error';
            statusBadge.className = 'status-badge disconnected';
            connectBtn.style.display = 'inline-block';
        }
    }

    document.getElementById('connect-google-calendar')?.addEventListener('click', () => {
        window.location.href = authorizeUrl('/auth/google-calendar/authorize');
    });

    document.getElementById('disconnect-google-calendar')?.addEventListener('click', async () => {
        if (!confirm('Are you sure you want to disconnect Google Calendar?')) {
            return;
        }

        const token = localStorage.getItem('pkm-authToken');

        try {
            const response = await fetch('/auth/google-calendar/disconnect', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${token}`
                }
            });

            if (response.ok) {
                alert('Google Calendar disconnected successfully');
                checkGoogleCalendarStatus();
            } else {
                alert('Failed to disconnect Google Calendar');
            }
        } catch (error) {
            console.error('Error disconnecting Google Calendar:', error);
            alert('Error disconnecting Google Calendar');
        }
    });

    // Gmail Integration Management
    async function checkGmailStatus() {
        const token = localStorage.getItem('pkm-authToken');
        const statusBadge = document.getElementById('gmail-status');
        const connectBtn = document.getElementById('connect-gmail');
        const disconnectBtn = document.getElementById('disconnect-gmail');

        try {
            const response = await fetch('/auth/google-gmail/status', {
                headers: {
                    'Authorization': `Bearer ${token}`
                }
            });

            const data = await response.json();

            if (data.connected) {
                statusBadge.textContent = 'Connected';
                statusBadge.className = 'status-badge connected';
                disconnectBtn.style.display = 'inline-block';
                connectBtn.style.display = 'none';
            } else {
                statusBadge.textContent = 'Not Connected';
                statusBadge.className = 'status-badge disconnected';
                connectBtn.style.display = 'inline-block';
                disconnectBtn.style.display = 'none';
            }
        } catch (error) {
            console.error('Error checking Gmail status:', error);
            statusBadge.textContent = 'Error';
            statusBadge.className = 'status-badge disconnected';
            connectBtn.style.display = 'inline-block';
        }
    }

    document.getElementById('connect-gmail')?.addEventListener('click', () => {
        window.location.href = authorizeUrl('/auth/google-gmail/authorize');
    });

    document.getElementById('disconnect-gmail')?.addEventListener('click', async () => {
        if (!confirm('Are you sure you want to disconnect Gmail?')) {
            return;
        }

        const token = localStorage.getItem('pkm-authToken');

        try {
            const response = await fetch('/auth/google-gmail/disconnect', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${token}`
                }
            });

            if (response.ok) {
                alert('Gmail disconnected successfully');
                checkGmailStatus();
            } else {
                alert('Failed to disconnect Gmail');
            }
        } catch (error) {
            console.error('Error disconnecting Gmail:', error);
            alert('Error disconnecting Gmail');
        }
    });

    // Logout handler
    document.getElementById('logout-btn')?.addEventListener('click', () => {
        localStorage.removeItem('pkm-authToken');
        window.location.href = '/';
    });

    // Load build version from service worker
    async function loadBuildVersion() {
        const buildVersionEl = document.getElementById('build-version');

        try {
            // Fetch the service worker file to extract the build timestamp
            const response = await fetch('/sw.js');
            const swCode = await response.text();

            // Extract BUILD_TIMESTAMP from the service worker code
            const match = swCode.match(/BUILD_TIMESTAMP\s*=\s*['"]([^'"]+)['"]/);

            if (match && match[1]) {
                const timestamp = match[1];
                // Format the timestamp nicely
                const date = new Date(timestamp);
                const formatted = date.toLocaleString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit',
                    timeZoneName: 'short'
                });
                buildVersionEl.textContent = formatted;
            } else {
                buildVersionEl.textContent = 'Unknown';
            }
        } catch (error) {
            console.error('Error loading build version:', error);
            buildVersionEl.textContent = 'Error';
        }
    }

    // Auto-save settings management
    const autoSaveToggle = document.getElementById('auto-save-toggle');
    const autoSaveDelaySetting = document.getElementById('auto-save-delay-setting');
    const autoSaveDelay = document.getElementById('auto-save-delay');

    // Load settings - default to enabled unless explicitly set to 'false'
    if (autoSaveToggle) {
        autoSaveToggle.checked = localStorage.getItem(STORAGE_KEYS.AUTO_SAVE_ENABLED) !== 'false';
        if (autoSaveToggle.checked) {
            autoSaveDelaySetting.style.display = 'block';
        }
    }

    if (autoSaveDelay) {
        autoSaveDelay.value = localStorage.getItem(STORAGE_KEYS.AUTO_SAVE_DELAY) || '2000';
    }

    // Save on change
    autoSaveToggle?.addEventListener('change', () => {
        localStorage.setItem(STORAGE_KEYS.AUTO_SAVE_ENABLED, autoSaveToggle.checked.toString());
        if (autoSaveToggle.checked) {
            autoSaveDelaySetting.style.display = 'block';
        } else {
            autoSaveDelaySetting.style.display = 'none';
        }
    });

    autoSaveDelay?.addEventListener('change', () => {
        localStorage.setItem(STORAGE_KEYS.AUTO_SAVE_DELAY, autoSaveDelay.value);
    });

    // ---- Scheduled Tasks ----

    const authHeaders = () => {
        const token = localStorage.getItem('pkm-authToken');
        return { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' };
    };

    async function loadBudget() {
        try {
            const res = await fetch('/api/scheduled-tasks/budget', { headers: authHeaders() });
            if (!res.ok) return;
            const d = await res.json();
            const pct = Math.max(d.input_pct, d.output_pct);
            const fill = document.getElementById('budget-bar-fill') as HTMLElement;
            fill.style.width = `${Math.min(pct, 100)}%`;
            fill.className = 'budget-bar-fill' + (pct >= 95 ? ' critical' : pct >= 80 ? ' warning' : '');
            document.getElementById('budget-summary')!.textContent = `${pct.toFixed(0)}% used today`;
            document.getElementById('budget-input')!.textContent = `Input: ${(d.input_tokens / 1000).toFixed(0)}k / ${(d.input_limit / 1_000_000).toFixed(1)}M`;
            document.getElementById('budget-output')!.textContent = `Output: ${(d.output_tokens / 1000).toFixed(0)}k / ${(d.output_limit / 1000).toFixed(0)}k`;
            document.getElementById('budget-runs')!.textContent = `Runs: ${d.task_runs}`;
        } catch (e) {
            console.error('Error loading budget:', e);
        }
    }

    function formatDateTime(iso: string | null): string {
        if (!iso) return '—';
        const d = new Date(iso + 'Z'); // treat as UTC
        return d.toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
    }

    async function loadTasks() {
        const container = document.getElementById('task-list')!;
        try {
            const res = await fetch('/api/scheduled-tasks', { headers: authHeaders() });
            if (!res.ok) { container.innerHTML = '<p class="loading-text">Failed to load tasks</p>'; return; }
            const tasks = await res.json();
            if (tasks.length === 0) {
                container.innerHTML = '<p class="loading-text">No scheduled tasks yet.</p>';
                return;
            }

            // Sort: heartbeat first, then by id
            tasks.sort((a: any, b: any) => (b.is_heartbeat ? 1 : 0) - (a.is_heartbeat ? 1 : 0) || a.id - b.id);

            container.innerHTML = tasks.map((t: any) => `
                <div class="task-card ${t.is_heartbeat ? 'heartbeat' : ''} ${!t.enabled ? 'disabled' : ''}" data-id="${t.id}">
                    <div class="task-card-header">
                        <span class="task-card-title">
                            ${escapeHtml(t.name)}
                            ${t.is_heartbeat ? '<span class="heartbeat-badge">heartbeat</span>' : ''}
                        </span>
                        <div class="task-card-actions">
                            <label class="toggle-label" style="gap: 0.4rem; font-size: 0.8rem;">
                                <input type="checkbox" class="toggle-input task-toggle" data-id="${t.id}" ${t.enabled ? 'checked' : ''} style="width: 36px; height: 18px;">
                            </label>
                            <button class="btn-run" data-id="${t.id}">Run Now</button>
                            <button class="btn-edit" data-id="${t.id}">Edit</button>
                            ${!t.is_heartbeat ? `<button class="btn-delete" data-id="${t.id}" data-name="${escapeAttr(t.name)}">Delete</button>` : ''}
                        </div>
                    </div>
                    <div class="task-card-meta">
                        <span>${escapeHtml(t.schedule_type)}: <code>${escapeHtml(t.schedule_expr)}</code></span>
                        <span>Last: ${formatDateTime(t.last_run_at)}</span>
                        <span>Next: ${formatDateTime(t.next_run_at)}</span>
                    </div>
                    <div class="task-card-prompt">${escapeHtml(t.prompt).substring(0, 200)}${t.prompt.length > 200 ? '...' : ''}</div>
                </div>
            `).join('');

            // Toggle event listeners
            container.querySelectorAll('.task-toggle').forEach(el => {
                el.addEventListener('change', async (e) => {
                    const id = (e.target as HTMLInputElement).dataset.id;
                    await fetch(`/api/scheduled-tasks/${id}/toggle`, { method: 'POST', headers: authHeaders() });
                    loadTasks();
                });
            });

            // Action buttons: attach listeners with data-attributes rather than inline
            // onclick with interpolated task names — a name containing a quote or HTML
            // would otherwise break the handler or inject markup.
            container.querySelectorAll<HTMLButtonElement>('.btn-run').forEach(btn => {
                btn.addEventListener('click', () => runTaskNow(Number(btn.dataset.id)));
            });
            container.querySelectorAll<HTMLButtonElement>('.btn-edit').forEach(btn => {
                btn.addEventListener('click', () => editTask(Number(btn.dataset.id)));
            });
            container.querySelectorAll<HTMLButtonElement>('.btn-delete').forEach(btn => {
                btn.addEventListener('click', () => deleteTask(Number(btn.dataset.id), btn.dataset.name || ''));
            });
        } catch (e) {
            console.error('Error loading tasks:', e);
            container.innerHTML = '<p class="loading-text">Error loading tasks</p>';
        }
    }

    function escapeHtml(text: string): string {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function escapeAttr(text: string): string {
        return text.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;');
    }

    async function runTaskNow(id: number) {
        if (!confirm('Run this task now?')) return;
        try {
            await fetch(`/api/scheduled-tasks/${id}/run`, { method: 'POST', headers: authHeaders() });
            alert('Task started in background');
        } catch (e) {
            alert('Failed to start task');
        }
    }

    async function deleteTask(id: number, name: string) {
        if (!confirm(`Delete task "${name}"?`)) return;
        try {
            await fetch(`/api/scheduled-tasks/${id}`, { method: 'DELETE', headers: authHeaders() });
            loadTasks();
        } catch (e) {
            alert('Failed to delete task');
        }
    }

    function resetTaskForm() {
        (document.getElementById('edit-task-id') as HTMLInputElement).value = '';
        (document.getElementById('new-task-name') as HTMLInputElement).value = '';
        (document.getElementById('new-task-name') as HTMLInputElement).disabled = false;
        (document.getElementById('new-task-prompt') as HTMLTextAreaElement).value = '';
        (document.getElementById('new-task-schedule-type') as HTMLSelectElement).value = 'cron';
        (document.getElementById('new-task-schedule-expr') as HTMLInputElement).value = '';
        (document.getElementById('new-task-max-turns') as HTMLInputElement).value = '10';
        (document.getElementById('new-task-max-input') as HTMLInputElement).value = '200000';
        (document.getElementById('new-task-max-output') as HTMLInputElement).value = '10000';
        document.getElementById('task-form-title')!.textContent = 'New Scheduled Task';
        document.getElementById('save-task-btn')!.textContent = 'Create Task';
        document.getElementById('task-form-status')!.textContent = '';
    }

    async function editTask(id: number) {
        try {
            const res = await fetch('/api/scheduled-tasks', { headers: authHeaders() });
            if (!res.ok) { alert('Failed to load task'); return; }
            const tasks = await res.json();
            const t = tasks.find((x: any) => x.id === id);
            if (!t) { alert('Task not found'); return; }

            (document.getElementById('edit-task-id') as HTMLInputElement).value = String(t.id);
            (document.getElementById('new-task-name') as HTMLInputElement).value = t.name;
            // Heartbeat name is meaningful to the backend — don't allow renaming it.
            (document.getElementById('new-task-name') as HTMLInputElement).disabled = !!t.is_heartbeat;
            (document.getElementById('new-task-prompt') as HTMLTextAreaElement).value = t.prompt || '';
            (document.getElementById('new-task-schedule-type') as HTMLSelectElement).value = t.schedule_type;
            (document.getElementById('new-task-schedule-expr') as HTMLInputElement).value = t.schedule_expr;
            (document.getElementById('new-task-max-turns') as HTMLInputElement).value = String(t.max_turns ?? 10);
            (document.getElementById('new-task-max-input') as HTMLInputElement).value = String(t.max_input_tokens ?? 200000);
            (document.getElementById('new-task-max-output') as HTMLInputElement).value = String(t.max_output_tokens ?? 10000);
            document.getElementById('task-form-title')!.textContent = `Edit: ${t.name}`;
            document.getElementById('save-task-btn')!.textContent = 'Save Changes';

            document.getElementById('add-task-form')!.style.display = 'block';
            document.getElementById('add-task-btn')!.style.display = 'none';
            document.getElementById('add-task-form')!.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } catch (e) {
            alert('Failed to load task for editing');
        }
    }

    // Add task form
    document.getElementById('add-task-btn')?.addEventListener('click', () => {
        resetTaskForm();
        document.getElementById('add-task-form')!.style.display = 'block';
        document.getElementById('add-task-btn')!.style.display = 'none';
    });

    document.getElementById('cancel-task-btn')?.addEventListener('click', () => {
        resetTaskForm();
        document.getElementById('add-task-form')!.style.display = 'none';
        document.getElementById('add-task-btn')!.style.display = 'inline-block';
    });

    document.getElementById('save-task-btn')?.addEventListener('click', async () => {
        const editId = (document.getElementById('edit-task-id') as HTMLInputElement).value;
        const name = (document.getElementById('new-task-name') as HTMLInputElement).value.trim();
        const prompt = (document.getElementById('new-task-prompt') as HTMLTextAreaElement).value.trim();
        const scheduleType = (document.getElementById('new-task-schedule-type') as HTMLSelectElement).value;
        const scheduleExpr = (document.getElementById('new-task-schedule-expr') as HTMLInputElement).value.trim();
        const maxTurns = parseInt((document.getElementById('new-task-max-turns') as HTMLInputElement).value) || 10;
        const maxInput = parseInt((document.getElementById('new-task-max-input') as HTMLInputElement).value) || 200000;
        const maxOutput = parseInt((document.getElementById('new-task-max-output') as HTMLInputElement).value) || 10000;
        const statusEl = document.getElementById('task-form-status')!;

        if (!name || !prompt || !scheduleExpr) {
            statusEl.textContent = 'Please fill in name, prompt, and schedule expression.';
            statusEl.className = 'status-text error';
            return;
        }

        const isEdit = editId !== '';
        const url = isEdit ? `/api/scheduled-tasks/${editId}` : '/api/scheduled-tasks';
        const method = isEdit ? 'PUT' : 'POST';
        const body: Record<string, any> = {
            prompt,
            schedule_type: scheduleType,
            schedule_expr: scheduleExpr,
            max_turns: maxTurns,
            max_input_tokens: maxInput,
            max_output_tokens: maxOutput,
        };
        // PUT also allows name; on the heartbeat task the name field is disabled (frozen).
        if (!isEdit || !(document.getElementById('new-task-name') as HTMLInputElement).disabled) {
            body.name = name;
        }

        try {
            const res = await fetch(url, {
                method,
                headers: authHeaders(),
                body: JSON.stringify(body),
            });

            if (res.ok) {
                document.getElementById('add-task-form')!.style.display = 'none';
                document.getElementById('add-task-btn')!.style.display = 'inline-block';
                resetTaskForm();
                loadTasks();
            } else {
                const data = await res.json();
                statusEl.textContent = data.error || (isEdit ? 'Failed to update task' : 'Failed to create task');
                statusEl.className = 'status-text error';
            }
        } catch (e) {
            statusEl.textContent = isEdit ? 'Error updating task' : 'Error creating task';
            statusEl.className = 'status-text error';
        }
    });

    // Recent runs
    async function loadRecentRuns() {
        const container = document.getElementById('recent-runs')!;
        try {
            const res = await fetch('/api/scheduled-tasks/runs?limit=10', { headers: authHeaders() });
            if (!res.ok) { container.innerHTML = '<p class="loading-text">Failed to load runs</p>'; return; }
            const runs = await res.json();
            if (runs.length === 0) {
                container.innerHTML = '<p class="loading-text">No runs yet.</p>';
                return;
            }

            container.innerHTML = runs.map((r: any) => `
                <div class="run-item">
                    <div>
                        <span class="run-status ${r.status}">${r.status}</span>
                        <span style="margin-left: 0.5rem; font-weight: 500;">Task #${r.task_id}</span>
                        ${r.summary ? `<div class="run-summary">${escapeHtml(r.summary).substring(0, 150)}</div>` : ''}
                        ${r.error ? `<div class="run-summary" style="color: #dc3545;">${escapeHtml(r.error).substring(0, 150)}</div>` : ''}
                    </div>
                    <div class="run-meta">
                        <div>${formatDateTime(r.started_at)}</div>
                        <div>${r.turns_used} turns, ${((r.input_tokens + r.output_tokens) / 1000).toFixed(0)}k tokens</div>
                    </div>
                </div>
            `).join('');
        } catch (e) {
            console.error('Error loading runs:', e);
            container.innerHTML = '<p class="loading-text">Error loading runs</p>';
        }
    }

    // ---- Self-Improvement ----

    function handleUnauthorized() {
        localStorage.removeItem('pkm-authToken');
        window.location.href = '/';
    }

    async function loadPromptAmendments() {
        const container = document.getElementById('si-amendments')!;
        try {
            const res = await fetch('/api/prompt-amendments', { headers: authHeaders() });
            if (res.status === 401) { handleUnauthorized(); return; }
            if (!res.ok) {
                container.innerHTML = '<p class="loading-text">Failed to load proposals</p>';
                return;
            }
            const amendments = await res.json();

            if (amendments.length === 0) {
                container.innerHTML = '<p class="loading-text">No pending prompt change proposals.</p>';
                return;
            }

            container.innerHTML = amendments.map((a: any) => {
                const data = a.rule_data || {};
                const action = data.action || 'add';
                const section = data.section || '';
                const proposedText = data.proposed_text || a.rule_text || '';
                const reason = data.reason || '';

                return `
                    <div class="amendment-card" data-id="${a.id}">
                        <div class="amendment-text">
                            <strong>${escapeHtml(String(action).toUpperCase())}</strong>${section ? ` in <em>${escapeHtml(section)}</em>` : ''}
                        </div>
                        <div class="amendment-proposed">${escapeHtml(proposedText)}</div>
                        ${reason ? `<div class="amendment-text"><strong>Reason:</strong> ${escapeHtml(reason)}</div>` : ''}
                        <div class="amendment-meta">
                            Confidence: ${Math.round((a.confidence ?? 0) * 100)}% &middot; Proposed ${formatDateTime(a.created_at)}
                        </div>
                        <div class="amendment-actions">
                            <button class="btn-approve" data-id="${a.id}">Approve</button>
                            <button class="btn-reject" data-id="${a.id}">Reject</button>
                        </div>
                    </div>
                `;
            }).join('');

            container.querySelectorAll<HTMLButtonElement>('.btn-approve').forEach(btn => {
                btn.addEventListener('click', () => approveAmendment(Number(btn.dataset.id)));
            });
            container.querySelectorAll<HTMLButtonElement>('.btn-reject').forEach(btn => {
                btn.addEventListener('click', () => rejectAmendment(Number(btn.dataset.id)));
            });
        } catch (e) {
            console.error('Error loading prompt amendments:', e);
            container.innerHTML = '<p class="loading-text">Error loading proposals</p>';
        }
    }

    async function approveAmendment(id: number) {
        if (!confirm('Approve this prompt change? It will take effect immediately.')) return;
        try {
            const res = await fetch(`/api/prompt-amendments/${id}/approve`, { method: 'POST', headers: authHeaders() });
            if (res.status === 401) { handleUnauthorized(); return; }
            if (res.ok) {
                loadPromptAmendments();
            } else {
                alert('Failed to approve amendment');
            }
        } catch (e) {
            console.error('Error approving amendment:', e);
            alert('Error approving amendment');
        }
    }

    async function rejectAmendment(id: number) {
        if (!confirm('Reject this prompt change?')) return;
        try {
            const res = await fetch(`/api/prompt-amendments/${id}/reject`, { method: 'POST', headers: authHeaders() });
            if (res.status === 401) { handleUnauthorized(); return; }
            if (res.ok) {
                loadPromptAmendments();
            } else {
                alert('Failed to reject amendment');
            }
        } catch (e) {
            console.error('Error rejecting amendment:', e);
            alert('Error rejecting amendment');
        }
    }

    async function loadLastSelfImproveRun() {
        const container = document.getElementById('si-last-run')!;
        try {
            const res = await fetch('/admin/self-improve/log', { headers: authHeaders() });
            if (res.status === 401) { handleUnauthorized(); return; }
            if (!res.ok) {
                container.innerHTML = '<p class="loading-text">Failed to load run info</p>';
                return;
            }
            const data = await res.json();
            const recentRuns = data.recent_runs || [];

            // Prefer the persisted DB history (survives server restarts); fall back to
            // the in-memory last_run only if no run has ever been logged to the DB.
            let run: any = null;
            let fromDb = true;
            if (recentRuns.length > 0) {
                run = recentRuns[0];
            } else if (data.last_run) {
                run = data.last_run;
                fromDb = false;
            }

            if (!run) {
                container.innerHTML = '<p class="loading-text">No self-improvement runs yet.</p>';
                return;
            }

            const turns = fromDb ? String(run.turns_used ?? '—') : (run.budget?.turns ?? '—');
            const inputTokens = fromDb
                ? (run.input_tokens != null ? `${(run.input_tokens / 1000).toFixed(0)}k` : '—')
                : (run.budget?.input_tokens ?? '—');
            const outputTokens = fromDb
                ? (run.output_tokens != null ? `${(run.output_tokens / 1000).toFixed(0)}k` : '—')
                : (run.budget?.output_tokens ?? '—');
            const summary = run.summary || '(no summary)';

            container.innerHTML = `
                <div class="si-run-summary">${escapeHtml(summary)}</div>
                <div class="si-run-meta">
                    <span>Started: ${formatDateTime(run.started_at)}</span>
                    <span>Completed: ${formatDateTime(run.completed_at)}</span>
                    <span>Turns: ${escapeHtml(turns)}</span>
                    <span>Input tokens: ${escapeHtml(inputTokens)}</span>
                    <span>Output tokens: ${escapeHtml(outputTokens)}</span>
                </div>
                ${run.error ? `<div class="si-run-error">Error: ${escapeHtml(run.error)}</div>` : ''}
            `;
        } catch (e) {
            console.error('Error loading last self-improvement run:', e);
            container.innerHTML = '<p class="loading-text">Error loading run info</p>';
        }
    }

    async function loadActiveRulesSummary() {
        const container = document.getElementById('si-rules-summary')!;
        try {
            const res = await fetch('/api/learned-rules', { headers: authHeaders() });
            if (res.status === 401) { handleUnauthorized(); return; }
            if (!res.ok) {
                container.innerHTML = '<p class="loading-text">Failed to load rules</p>';
                return;
            }
            const rules = await res.json();
            const active = rules.filter((r: any) => r.is_active);

            if (active.length === 0) {
                container.innerHTML = '<p class="loading-text">No active learned rules.</p>';
                return;
            }

            const counts = new Map<string, number>();
            for (const r of active) {
                counts.set(r.rule_type, (counts.get(r.rule_type) || 0) + 1);
            }
            const rows = Array.from(counts.entries())
                .sort((a, b) => b[1] - a[1])
                .map(([type, count]) => `<div class="si-rule-type-row"><span>${escapeHtml(type.replace(/_/g, ' '))}</span><span>${count}</span></div>`)
                .join('');

            container.innerHTML = `<div class="si-rule-type-row"><strong>Total active</strong><strong>${active.length}</strong></div>${rows}`;
        } catch (e) {
            console.error('Error loading learned rules:', e);
            container.innerHTML = '<p class="loading-text">Error loading rules</p>';
        }
    }

    // Load data on page load
    loadUserContext();
    checkTickTickStatus();
    checkGoogleCalendarStatus();
    checkGmailStatus();
    loadBuildVersion();
    loadBudget();
    loadTasks();
    loadRecentRuns();
    loadPromptAmendments();
    loadLastSelfImproveRun();
    loadActiveRulesSummary();
</script>
